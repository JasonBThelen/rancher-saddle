{
  "name": "rancher-saddle",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint overlay playwright helm/rancher-saddle/files",
    "format": "prettier --write 'overlay/**/*.{js,css}' 'playwright/**/*.mjs'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  }
}
