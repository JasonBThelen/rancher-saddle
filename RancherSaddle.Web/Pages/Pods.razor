@page "/pods"
@using RancherSaddle.Api.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="pods-container">
    <div class="header-actions">
        <h2 class="page-title">Cluster Pods</h2>
        <button class="btn-refresh" @onclick="RefreshPods">
            <span class="bi bi-arrow-clockwise"></span> Refresh
        </button>
    </div>

    @if (string.IsNullOrEmpty(clusterId))
    {
        <div class="empty-state">
            <p>No cluster selected. Please pick a cluster from the Dashboard.</p>
            <button class="btn-primary" @onclick="GoHome">Back to Dashboard</button>
        </div>
    }
    else if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading pods...</p>
        </div>
    }
    else if (pods == null || !pods.Any())
    {
        <div class="empty-state">
            <p>No pods found for this cluster.</p>
        </div>
    }
    else
    {
        <div class="pods-list">
            @foreach (var pod in pods)
            {
                <div class="pod-card">
                    <div class="pod-info">
                        <span class="pod-name">@pod.Name</span>
                        <span class="pod-status @(pod.Status == "Running" ? "status-ok" : "status-err")">@pod.Status</span>
                    </div>
                    <button class="btn-restart" @onclick="() => ConfirmRestart(pod)">
                        <span class="bi bi-power"></span> Restart
                    </button>
                </div>
            }
        </div>
    }
</div>

@if (showConfirmModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3>Confirm Restart</h3>
            <p>Are you sure you want to restart <strong>@selectedPod?.Name</strong>?</p>
            <p class="modal-warning">This will delete the pod and trigger a fresh rollout.</p>
            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-confirm" @onclick="ExecuteRestart">Yes, Restart</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? clusterId { get; set; }
    private List<PodPodDto> pods = new();
    private bool isLoading = true;
    private bool showConfirmModal = false;
    private PodPodDto? selectedPod;

    protected override async Task OnInitializedAsync()
    {
        await RefreshPods();
    }

    private async Task RefreshPods()
    {
        if (string.IsNullOrEmpty(clusterId)) return;
        isLoading = true;
        try
        {
            pods = await Http.GetFromJsonAsync<List<PodPodDto>>($"api/clusters/{clusterId}/pods") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            pods = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ConfirmRestart(PodPodDto pod)
    {
        selectedPod = pod;
        showConfirmModal = true;
    }

    private void CloseModal()
    {
        showConfirmModal = false;
        selectedPod = null;
    }

    private async Task ExecuteRestart()
    {
        if (selectedPod == null || string.IsNullOrEmpty(clusterId)) return;
        
        try
        {
            var response = await Http.DeleteAsync($"/api/clusters/{clusterId}/pods/{selectedPod.Id}/restart");
            if (response.IsSuccessStatusCode)
            {
                CloseModal();
                await RefreshPods();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Restart failed: {ex.Message}");
        }
    }

    private void GoHome() => Navigation.NavigateTo("/");
}

<style>
    .pods-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-title {
        margin: 0;
        font-size: 1.5rem;
        color: #fff;
    }

    .btn-refresh {
        background: #333;
        color: #fff;
        border: 1px solid #444;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
    }

    .pods-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .pod-card {
        background: #1f1f1f;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .pod-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .pod-name {
        font-weight: bold;
        color: #fff;
        font-size: 1rem;
    }

    .pod-status {
        font-size: 0.8rem;
        font-weight: 500;
    }

    .status-ok { color: #2ecc71; }
    .status-err { color: #e74c3c; }

    .btn-restart {
        background: #333;
        color: #ff4d4d;
        border: 1px solid #ff4d4d;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-restart:active {
        background: #ff4d4d;
        color: #fff;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 1rem;
    }

    .modal-content {
        background: #2a2a2a;
        padding: 2rem;
        border-radius: 16px;
        max-width: 400px;
        width: 100%;
        text-align: center;
        border: 1px solid #444;
        color: #fff;
    }

    .modal-warning {
        color: #aaa;
        font-size: 0.9rem;
        margin: 1rem 0;
    }

    .modal-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2rem;
    }

    .btn-cancel {
        background: #444;
        color: #fff;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
    }

    .btn-confirm {
        background: #e74c3c;
        color: #fff;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
    }

    .loading-state, .empty-state {
        text-align: center;
        padding: 3rem 0;
        color: #888;
    }

    .spinner {
        width: 30px;
        height: 30px;
        border: 3px solid #333;
        border-top: 3px solid #4dabff;
        border-radius: 50%;
        margin: 0 auto 1rem auto;
        animation: spin 1s linear infinite;
    }

    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>
